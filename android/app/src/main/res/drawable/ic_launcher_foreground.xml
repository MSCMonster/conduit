    <path
        android:fillColor="#000000"
        android:fillType="evenOdd"
        android:pathData="M26,54 A19,19 0 1,0 64,54 A19,19 0 1,0 26,54 Z M34,54 A11,11 0 1,0 56,54 A11,11 0 1,0 34,54 Z" />
    <!-- I：圆角竖条 -->
    <path
        android:fillColor="#000000"
        android:pathData="M74.5,35 H77.5 A4.5,4.5 0 0 1 82,39.5 V68.5 A4.5,4.5 0 0 1 77.5,73 H74.5 A4.5,4.5 0 0 1 70,68.5 V39.5 A4.5,4.5 0 0 1 74.5,35 Z" />
</vector>
